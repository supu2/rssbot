xmpp:
  host: "xmpp.<domain>"
  port: 5222
  jid: "rssbot@<domain>"
  password: "<password>"

rss:
  poll_interval: 600  # 1 hour in seconds
  user_agent: "Mozilla/5.0 (Windows NT 10.0; Win64; x64; rv:146.0) Gecko/20100101 Firefox/146.0"

database:
  type: sqlite  # sqlite or postgres
  path: "./data/rss.db"

  # For postgres use:
  # type: postgres
  # host: "localhost"
  # port: 5432
  # user: "rssbot"
  # password: "your-password"
  # dbname: "rssbot"